@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
}

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@model FinanceTracker.Models.Transactions;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h1>Login</h1>

<form method="post">
    <input type="text" name="email" placeholder="Enter Resistered Email" class="form-control" required /><br />
    <input type="password" name="password" placeholder="Enter Password"  class="form-control" required/> <br />
    <button class="btn btn-success">Login</button>
    <button class="btn btn-primary" asp-controller="Account" asp-action="Register"  onclick="window.location.href='/Account/Register'" >New User</button>
</form>